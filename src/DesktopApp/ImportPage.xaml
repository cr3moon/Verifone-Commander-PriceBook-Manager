<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VerifoneCommander.PriceBookManager.DesktopApp.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VerifoneCommander.PriceBookManager.DesktopApp"
    xmlns:vm="using:VerifoneCommander.PriceBookManager.DesktopApp.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Info bar -->
        <InfoBar Grid.Row="0"
                 Margin="{StaticResource VerticalMargin_FirstElement}"
                 Message="{x:Bind ViewModel.InfoBar.Message, Mode=OneWay}"
                 IsOpen="{x:Bind ViewModel.InfoBar.IsOpen, Mode=TwoWay}"
                 Severity="{x:Bind ViewModel.InfoBar.Severity, Mode=OneWay, Converter={StaticResource InfoBarSeverityConverter}}" />

        <!-- Choose file + template hint -->
        <StackPanel Grid.Row="1"
                    Spacing="6"
                    Margin="{StaticResource VerticalMargin_NotFirstElement}">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Click="ChooseFileButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <SymbolIcon Symbol="OpenFile" Margin="{StaticResource IconWithRightTextMargin}" />
                        <TextBlock Text="Choose CSV file…" />
                    </StackPanel>
                </Button>
                <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.FileName, Mode=OneWay}" />
            </StackPanel>
            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                       TextWrapping="Wrap"
                       Text="CSV columns (header row required): upc, modifier, description, department, price. modifier is optional (defaults to 0)." />
        </StackPanel>

        <!-- Import action -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="{StaticResource VerticalMargin_NotFirstElement}"
                    VerticalAlignment="Center">
            <Button x:Name="ImportButton"
                    Content="{x:Bind ViewModel.ImportButtonText, Mode=OneWay}"
                    IsEnabled="{x:Bind ViewModel.CanImport, Mode=OneWay}"
                    Click="ImportButton_Click" />
        </StackPanel>

        <!-- Column headers -->
        <Border Grid.Row="3"
                Margin="{StaticResource VerticalMargin_NotFirstElement}"
                Padding="12,8"
                Background="{ThemeResource SystemChromeMediumLowColor}"
                Visibility="{x:Bind ViewModel.HasResult, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Line" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="Status" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="UPC" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="Mod" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="Description" FontWeight="SemiBold" />
                <TextBlock Grid.Column="5" Text="Department" FontWeight="SemiBold" />
                <TextBlock Grid.Column="6" Text="Price" FontWeight="SemiBold" HorizontalTextAlignment="Right" />
                <TextBlock Grid.Column="7" Text="Notes" FontWeight="SemiBold" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <!-- Preview -->
        <ScrollView Grid.Row="4"
                    Margin="{StaticResource VerticalMargin_NotFirstElement}">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="2" />
                </ItemsRepeater.Layout>

                <DataTemplate x:DataType="vm:ImportRowVm">
                    <Border Background="{ThemeResource SystemChromeLowColor}">
                        <Grid Padding="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Bind LineNumber}" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Status}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Upc}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind Modifier}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{x:Bind Description}" />
                            <TextBlock Grid.Column="5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{x:Bind DepartmentName}" />
                            <TextBlock Grid.Column="6" VerticalAlignment="Center" HorizontalTextAlignment="Right" Text="{x:Bind Price}" />
                            <TextBlock Grid.Column="7" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap" Text="{x:Bind Message}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsRepeater>
        </ScrollView>
    </Grid>
</Page>
