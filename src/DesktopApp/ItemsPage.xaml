<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VerifoneCommander.PriceBookManager.DesktopApp.ItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VerifoneCommander.PriceBookManager.DesktopApp"
    xmlns:vm="using:VerifoneCommander.PriceBookManager.DesktopApp.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Info bar -->
        <InfoBar Grid.Row="0"
                 Margin="{StaticResource VerticalMargin_FirstElement}"
                 Message="{x:Bind ViewModel.InfoBar.Message, Mode=OneWay}"
                 IsOpen="{x:Bind ViewModel.InfoBar.IsOpen, Mode=TwoWay}"
                 Severity="{x:Bind ViewModel.InfoBar.Severity, Mode=OneWay, Converter={StaticResource InfoBarSeverityConverter}}" />

        <!-- Filter bar -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="16"
                    Margin="{StaticResource VerticalMargin_NotFirstElement}"
                    VerticalAlignment="Bottom">
            <TextBox Header="Filter"
                     Width="260"
                     PlaceholderText="UPC, modifier, or description"
                     Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Header="Department"
                      MinWidth="200"
                      ItemsSource="{x:Bind ViewModel.DepartmentNames, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedDepartmentName, Mode=TwoWay}" />
            <CheckBox Content="Food stamps"
                      VerticalAlignment="Bottom"
                      IsChecked="{x:Bind ViewModel.FoodStampsOnly, Mode=TwoWay}" />
            <CheckBox Content="Age-restricted"
                      VerticalAlignment="Bottom"
                      IsChecked="{x:Bind ViewModel.AgeRestrictedOnly, Mode=TwoWay}" />
            <Button VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <SymbolIcon Symbol="Refresh" Margin="{StaticResource IconWithRightTextMargin}" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Summary -->
        <TextBlock Grid.Row="2"
                   Margin="{StaticResource VerticalMargin_NotFirstElement}"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Text="{x:Bind ViewModel.Summary, Mode=OneWay}" />

        <!-- Column headers -->
        <Border Grid.Row="3"
                Margin="{StaticResource VerticalMargin_NotFirstElement}"
                Padding="12,8"
                Background="{ThemeResource SystemChromeMediumLowColor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="UPC" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="Modifier" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="Price" FontWeight="SemiBold" HorizontalTextAlignment="Right" />
                <TextBlock Grid.Column="5" Text="Department" FontWeight="SemiBold" Margin="12,0,0,0" />
                <TextBlock Grid.Column="6" Text="Description" FontWeight="SemiBold" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <!-- Items -->
        <ScrollView Grid.Row="4"
                    Margin="{StaticResource VerticalMargin_NotFirstElement}">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="2" />
                </ItemsRepeater.Layout>

                <DataTemplate x:DataType="vm:ItemRowVm">
                    <Border Background="{ThemeResource SystemChromeLowColor}">
                        <Grid Padding="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      MinWidth="0"
                                      VerticalAlignment="Center"
                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />

                            <Button Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Command="{x:Bind EditCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" Margin="{StaticResource IconWithRightTextMargin}" />
                                    <TextBlock Text="Edit" />
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Text="{x:Bind Ean13, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0:D14\}'}" />
                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Text="{x:Bind Modifier, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0:D3\}'}" />
                            <TextBlock Grid.Column="4"
                                       VerticalAlignment="Center"
                                       HorizontalTextAlignment="Right"
                                       Text="{x:Bind Price, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0:F2\}'}" />
                            <TextBlock Grid.Column="5"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Text="{x:Bind DepartmentName, Mode=OneWay}" />
                            <TextBlock Grid.Column="6"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{x:Bind Description, Mode=OneWay}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsRepeater>
        </ScrollView>
    </Grid>
</Page>
