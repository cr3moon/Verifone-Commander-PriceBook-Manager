<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="VerifoneCommander.PriceBookManager.DesktopApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VerifoneCommander.PriceBookManager.DesktopApp"
    xmlns:converters="using:VerifoneCommander.PriceBookManager.DesktopApp.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
            <converters:IntToSymbolConverter x:Key="IntToSymbolConverter" />
            <converters:StringFormatConverter x:Key="StringFormatConverter" />
            <converters:InfoBarSeverityConverter x:Key="InfoBarSeverityConverter" />
            <converters:UpcSeverityToBrushConverter x:Key="UpcSeverityToBrushConverter" />
            <converters:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter" />

            <!-- UPC issue severity brushes (color choices visible in both themes). -->
            <SolidColorBrush x:Key="UpcErrorBrush" Color="#D32F2F" />
            <SolidColorBrush x:Key="UpcWarningBrush" Color="#F57C00" />
            <SolidColorBrush x:Key="UpcInfoBrush" Color="#1976D2" />
            <SolidColorBrush x:Key="PossibleDuplicateBorderBrush" Color="#1976D2" />

            <!-- Possible-duplicates anchor row (the row the operator tapped). Purple on
                 purpose: visually distinct from the blue match borders without implying
                 good (green) or bad (red) — the anchor may itself be the one to remove. -->
            <SolidColorBrush x:Key="DuplicateAnchorBorderBrush" Color="#AB47BC" />

            <!-- Matched-word highlight in the duplicates side panel (highlighter-pen
                 yellow + black text, readable in both themes). -->
            <SolidColorBrush x:Key="DuplicateMatchHighlightBrush" Color="#FFF59D" />
            <SolidColorBrush x:Key="DuplicateMatchHighlightForegroundBrush" Color="#000000" />

            <Thickness x:Key="HeaderTextBoxMargin">0,0,0,10</Thickness>
            <Thickness x:Key="IconWithRightTextMargin">0,0,10,0</Thickness>

            <Thickness x:Key="VerticalMargin_FirstElement">0,0,0,10</Thickness>
            <Thickness x:Key="VerticalMargin_NotFirstElement">0,10</Thickness>

            <x:Double x:Key="GeneralTextBoxWidth">480</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
